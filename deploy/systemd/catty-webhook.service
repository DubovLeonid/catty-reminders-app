[Unit]
Description=Catty GitHub webhook handler
After=network.target

[Service]
Type=simple
User=lenya
Group=lenya
WorkingDirectory=/opt/catty-reminders-app
EnvironmentFile=-/opt/catty-reminders-app/.env
ExecStart=/opt/catty-reminders-app/.venv/bin/uvicorn webhook.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
